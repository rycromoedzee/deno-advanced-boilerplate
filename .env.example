# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
NODE_ENV=development
PUBLIC_APP_NAME=Pu App Name

PUBLIC_FRONTEND_URL=Frontend URL
PUBLIC_BACKEND_URL=Backend URL
BASE_DOMAIN=domain.com

# ============================================================================
# DATABASE CONFIGURATION (Multi-Tenant SQLite Architecture)
# ============================================================================

# Global Database (shared across all tenants)
# Local development: Uses file-based SQLite
# Production: Uses BunnyDB (libSQL over HTTPS)
GLOBAL_DB_URL=file:./.data/db/global.db
GLOBAL_DB_AUTH_TOKEN=

# Tenant Database Cache Configuration
TENANT_DB_CACHE_MAX=50

# BunnyDB API for provisioning new tenant databases
BUNNY_DB_API_KEY=

# ============================================================================
# CACHE CONFIGURATION
# ============================================================================
BLOOM_FILTER_ENABLED=true
CACHE_MULTI_TIER_ENABLED=true
CACHE_BUS_ENABLED=true
CACHE_L1_MAX_SIZE_MB=20
CACHE_L1_MAX_ENTRIES=10000

# Redis Cache Settings
CACHE_REDIS_ENABLED=true
CACHE_REDIS_HOST=192.168.100.82
CACHE_REDIS_PORT=6379
CACHE_REDIS_PASSWORD=
CACHE_REDIS_DB=0

# KeyDB Peer Discovery (Bunny.net Magic Containers - optional)
BUNNY_ACCESS_KEY=
KEYDB_PEER_POLL_INTERVAL_MS=30000

# ============================================================================
# STORAGE CONFIGURATION
# ============================================================================
STORAGE_FILE_ENCRYPTION="s1r70fexN/ovNVEpJeOttKQivhiOeNKaQqWWkMAl4Fo=" # openssl rand -base64 32

# Current storage type: local | s3 | bunny
STORAGE_TYPE=local

# --- S3 Storage (disabled) ---
# STORAGE_TYPE=s3
STORAGE_REGION=
STORAGE_NAME=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_ENDPOINT=

# --- Bunny Storage (disabled) ---
#STORAGE_TYPE=
#STORAGE_REGION=
#STORAGE_NAME=
#STORAGE_ACCESS_KEY=

# --- Public Storage (Bunny CDN) ---
STORAGE_PUBLIC_NAME=
STORAGE_PUBLIC_HOST=
STORAGE_PUBLIC_KEY=

# ============================================================================
# OBJECT STORAGE BACKUP (off-site, independent copy of user file bytes — 3-2-1)
# ============================================================================
# Disabled by default. Enable ONLY after configuring an INDEPENDENT provider
# (a DIFFERENT account than STORAGE_*). The boot guard
# (services/object-backup/preflight.ts) is fail-closed: it refuses to start if
# OBJECT_BACKUP_ENABLED=true with missing config, a credential shared with
# STORAGE_*, or local storage outside dev/test.
OBJECT_BACKUP_ENABLED=false

# Destination provider — must be a different account/provider than STORAGE_*.
#   local : dev/test only (writes under BACKUP_STORAGE_LOCAL_DIR)
#   s3    : needs REGION/NAME(bucket)/ACCESS_KEY/SECRET_KEY/ENDPOINT
#   bunny : needs REGION/NAME(zone)/ACCESS_KEY
BACKUP_STORAGE_TYPE=
BACKUP_STORAGE_REGION=
BACKUP_STORAGE_NAME=
BACKUP_STORAGE_ACCESS_KEY=
BACKUP_STORAGE_SECRET_KEY=
BACKUP_STORAGE_ENDPOINT=
# local-only base dir (dev/test); distinct from the live STORAGE local dir.
BACKUP_STORAGE_LOCAL_DIR=./.data-backup

# Batch / retention tuning. The backup schedule is fixed in jobs/registry.ts
# (every 2h, odd hours) and is no longer env-configurable.
OBJECT_BACKUP_DELETE_GRACE_DAYS=30
OBJECT_BACKUP_BATCH_LIMIT=500
OBJECT_BACKUP_JOB_TIMEOUT_MS=7200000
OBJECT_BACKUP_LOCK_REFRESH_INTERVAL_MS=600000

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
# Password Security
AUTH_PASSWORD_PEPPER="" # openssl rand -base64 32
AUTH_PEPPER_ROTATION=false
AUTH_PASSWORD_PEPPER_NEW=  # openssl rand -base64 32

# General Encryption
AUTH_GENERAL_ENCRYPTION_KEY="" # openssl rand -base64 32

# JWT Configuration
AUTH_JWT_PRIVATE_KEY=""
AUTH_JWT_PUBLIC_KEY=""
AUTH_JWT_ALGO=EdDSA
AUTH_JWT_CURVE=Ed25519

# JWT Token TTL (in seconds)
JWT_TTL_AUTH_EXPIRATION=900           # 15 mins
JWT_TTL_REFRESH_EXPIRATION=604800     # 7 days
JWT_TTL_LIFESPAN=3888000              # 45 days
JWT_TTL_LIFESPAN_LONG_LIVED=7776000   # 90 days
JWT_TTL_EMAIL=2592000                 # 30 days (long-lived for unsubscribe)
JWT_TTL_MAGIC=600                     # 10 minutes (short for security)
JWT_TTL_TWO_FACTOR=60                 # 1 minute (very short for 2FA)
JWT_TTL_VERIFY=60                     # 1 minute (very short for verification)
JWT_TTL_RESET=900                     # 15 minutes (secure window for password reset)
JWT_TTL_MULTI_USER=60                 # 1 minute (short window for user selection)

# API Keys
AUTH_API_KEY_PREFIX=     # Should prefix with a sk-
AUTH_REFRESH_SECRET_KEY=  # openssl rand 48 | base64 | tr '+/' '-_' | tr -d '='

# ============================================================================
# EMAIL/MAIL CONFIGURATION
# ============================================================================
MAIL_FROM_EMAIL=
MAIL_REPLY_TO=
MAIL_SECRET_KEY=
MAIL_SVIX_SECRET=
MAIL_WEBHOOK_URI= # openssl rand -hex 32 <== This is optional, but good to have to try and prevent URL scanning

# ============================================================================
# LOGGING CONFIGURATION   Using Betterstack
# ============================================================================
LOGGER_KEY=
LOGGER_URL=

# ============================================================================
# TRACING CONFIGURATION
# ============================================================================
TRACING_ENABLED=true

# ============================================================================
# THREAT INTELLIGENCE
# ============================================================================
THREAT_INTELLIGENCE_ENABLED=true

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_ENABLED=false
RATE_LIMIT_FAIL_CLOSED=false

# ============================================================================
# TIMING CONFIGURATION
# ============================================================================
# Enable/disable timing protection globally (useful for tests)
ENABLE_TIMING_PROTECTION=true

# Values in milliseconds for security delay operations
TIMING_PASSWORD_OPERATIONS_VALUE=175
TIMING_TWO_FACTOR_VALUE=100
TIMING_MULTI_USER_VALUE=120

# ============================================================================
# INTERNAL TOOLS
# ============================================================================
INTERNAL_TOOL_ACTIVE=true
INTERNAL_TOOL_IP_RESTRICTION=false
INTERNAL_TOOL_KEY= # openssl rand -base64 256 | tr '+/' '-_' | tr -d '='

# ============================================================================
# HIGH FREQUENCY ENTITIES CACHE
# ============================================================================
HIGH_FREQUENCY_USAGE_DOCUMENTS=true

# ============================================================================
# JOB CONFIGURATION
# ============================================================================
JOB_MODE=worker
WORKERS_MAX_DECRYPT=1
WORKERS_MAX_ENCRYPT=1
JOBS_ENFORCE_RUNNER_ALLOWLIST=true

# ============================================================================
# NOTIFICATIONS
# ============================================================================
NOTIFICATION_RETENTION_DAYS=30

# ============================================================================
# BOOTSTRAP
# ============================================================================
RUN_BOOTSTRAP=true

# ============================================================================
# BACKUP SERVICE
# ============================================================================
BACKUP_STORAGE_TYPE=bunny
BACKUP_STORAGE_NAME=
BACKUP_STORAGE_ACCESS_KEY=
BACKUP_STORAGE_REGION=

OBJECT_BACKUP_ENABLED=true
{
  "imports": {
    "@felix/argon2": "jsr:@felix/argon2@^3.0.5",
    "@noble/hashes": "jsr:@noble/hashes@^2.0.1",
    "@noble/curves": "jsr:@noble/curves@^1.8.1",
    "@db/redis": "jsr:@db/redis@^0.40.0",
    "@simplewebauthn/server": "jsr:@simplewebauthn/server@^13.1.2",
    "@simplewebauthn/types": "jsr:@simplewebauthn/types@^12.0.0",
    "@typescript-eslint/parser": "npm:@typescript-eslint/parser@^8.0.0",
    "eslint": "npm:eslint@^9.0.0",
    "typescript": "npm:typescript@~5.9.0",
    "drizzle-kit": "npm:drizzle-kit@^0.31.4",
    "openapi-typescript": "npm:openapi-typescript@^7",
    "drizzle-orm": "npm:drizzle-orm@0.45.1",
    "drizzle-orm/libsql": "npm:drizzle-orm@0.45.1/libsql",
    "@libsql/client": "npm:@libsql/client@^0.14.0",
    "@libsql/client/node": "npm:@libsql/client@^0.14.0/node",
    "ejs": "https://esm.sh/ejs@3.1.10",
    "hono": "npm:hono",
    "@hono/zod-openapi": "npm:@hono/zod-openapi",
    "hono/csrf": "npm:hono/csrf",
    "hono/cors": "npm:hono/cors",
    "hono/secure-headers": "npm:hono/secure-headers",
    "hono/cookie": "npm:hono/cookie",
    "hono/jwt": "npm:hono/jwt",
    "hono/http-exception": "npm:hono/http-exception",
    "html-to-text": "https://esm.sh/html-to-text@9.0.5",
    "nodemailer": "https://esm.sh/nodemailer@6.9.7",
    "@std/encoding": "jsr:@std/encoding@^1.0.5",
    "@std/path": "jsr:@std/path@^1.0.8",
    "onjara/optic": "jsr:@onjara/optic",
    "@bunny.net/storage-sdk": "https://esm.sh/@bunny.net/storage-sdk",
    "@matmen/imagescript": "jsr:@matmen/imagescript@^1.3.1",
    "@aws-sdk/client-s3": "https://esm.sh/@aws-sdk/client-s3@3.1016.0",
    "@aws-sdk/lib-storage": "https://esm.sh/@aws-sdk/lib-storage@3.1016.0",
    "bip39": "npm:bip39@3.1.0",
    "resend": "npm:resend@4.6.0",
    "scalar": "npm:@scalar/hono-api-reference",
    "@routes/": "./routes/",
    "@handlers/": "./handlers/",
    "@services/": "./services/",
    "@jobs/": "./jobs/",
    "@models/": "./models/",
    "@middleware/": "./middleware/",
    "@utils/": "./utils/",
    "@db/": "./db/",
    "@libs/": "./libs/",
    "@deps": "./deps.ts",
    "@config/": "./config/",
    "@logger/": "./services/logger/",
    "@constants/": "./constants/",
    "@interfaces/": "./interfaces/",
    "@std/dotenv/mod": "https://deno.land/std@0.220.1/dotenv/mod.ts",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@tests/": "./tests/"
  },
  "tasks": {
    "check": "deno fmt --check && deno lint && deno check main.ts",
    "check:openapi-docs": "deno run --no-check -A --env scripts/check-openapi-docs.ts",
    "generate:api-types": "deno run --no-check -A --env scripts/emit-openapi-spec.ts && deno run -A --node-modules-dir npm:openapi-typescript@^7 openapi.spec.json -o admin-ui/src/types/api.generated.ts",
    "check:api-types-drift": "deno task generate:api-types && echo 'Checking generated API types are committed (no schema→types drift)...' && git diff --exit-code -- admin-ui/src/types/api.generated.ts && echo 'Type-checking admin-ui against generated types...' && cd admin-ui && pnpm type-check",
    "lint:scripts": "deno lint scripts/",
    "dev": "deno run --watch --allow-all main.ts",
    "dev:inline": "JOBS_USE_INLINE=true deno run --watch --allow-all main.ts",
    "start": "deno run --allow-all main.ts",
    "start:inline": "JOBS_USE_INLINE=true deno run --allow-all main.ts",
    "jobs:standalone": "deno run --allow-all jobs/runners/standalone.ts",
    "jobs:check-overlaps": "deno run --allow-read --allow-env scripts/verify-job-overlaps.ts",
    "drizzle-kit": "deno --env -A --node-modules-dir npm:drizzle-kit",
    "db:generate:global": "deno --env -A --node-modules-dir npm:drizzle-kit generate --config drizzle.global.config.ts",
    "db:generate:tenant": "deno --env -A --node-modules-dir npm:drizzle-kit generate --config drizzle.tenant.config.ts",
    "admin-ui:build": "cd admin-ui && pnpm build",
    "admin-ui:dev": "cd admin-ui && pnpm build",
    "lint:eslint": "deno run -A --node-modules-dir npm:eslint@9 handlers services middleware utils constants"
  },
  "lint": {
    "exclude": [
      "static/",
      "node_modules/",
      "admin-ui/",
      "scripts/",
      "debug-testing/",
      "db/seed",
      "tests/",
      ".kilo/",
      ".claude/",
      ".agents/"
    ]
  },
  "deploy": {
    "project": "9aa599ab-7c73-44dd-ab41-9c77f9f2da11",
    "exclude": [
      "**/node_modules"
    ],
    "include": [],
    "entrypoint": "main.ts"
  },
  "fmt": {
    "lineWidth": 140,
    "exclude": [
      ".agents/",
      ".claude/"
    ]
  }
}
